{
  "_version": "1.65.0",
  "sap.app": {
    "id": "galactic.spacefarers",
    "type": "application",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "dataSources": {
      "mainService": {
        "uri": "/galaxy/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/metadata.xml",
          "odataVersion": "4.0"
        }
      }
    },
    "offline": false,
    "sourceTemplate": {
      "id": "fiori-elements.v4.fe.template"
    },
    "crossNavigation": {
      "inbounds": {
        "Spacefarers-display": {
          "semanticObject": "Spacefarers",
          "action": "display",
          "title": "{{appTitle}}",
          "subTitle": "{{appDescription}}",
          "icon": "sap-icon://person-placeholder",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archetype": "transactional"
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ushell": {},
        "sap.fe.templates": {}
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "galactic.spacefarers.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "SpacefarersList",
          "target": "SpacefarersList"
        },
        {
          "pattern": "Spacefarers({key}):?query:",
          "name": "SpacefarersDetail",
          "target": "SpacefarersDetail"
        }
      ],
      "targets": {
        "SpacefarersList": {
          "type": "Component",
          "id": "SpacefarersList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "Spacefarers",
              "variantManagement": "Page",
              "initialLoad": true,
              "navigation": {
                "Spacefarers": {
                  "detail": {
                    "route": "SpacefarersDetail"
                  }
                }
              },
              "navigationSettings": {
                "displayMode": "IconAndText"
              }
            }
          }
        },
        "SpacefarersDetail": {
          "type": "Component",
          "id": "SpacefarersDetail",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "Spacefarers",
              "navigationSettings": {}
            }
          }
        }
      }
    }
  }
}
